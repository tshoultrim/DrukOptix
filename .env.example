# Lovable Cloud (Supabase) credentials.
# Get these from: Lovable Cloud → Settings → API, OR your Supabase project dashboard.
# Both VITE_ prefixed (used by the browser via Vite) and unprefixed (used by SSR) are needed.

VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-OR-PUBLISHABLE-KEY"

SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-OR-PUBLISHABLE-KEY"

# Only needed if you call admin (server-side) helpers locally. Keep this SECRET.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
